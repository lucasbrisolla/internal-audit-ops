      <!-- ── CTI: Compliance, TI (center y=720) ── -->
      <bpmndi:BPMNShape id="Shape_LinkCatch_A" bpmnElement="LinkCatch_A">
        <dc:Bounds x="702" y="702" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="712" y="745" width="16" height="14"/></bpmndi:BPMNLabel>
