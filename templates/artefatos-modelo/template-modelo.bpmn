      <bpmndi:BPMNEdge id="Edge_Flow_PortalGW" bpmnElement="Flow_PortalGW">
        <di:waypoint x="2210" y="380"/>
        <di:waypoint x="2265" y="380"/>
      </bpmndi:BPMNEdge>

      <!-- Sim Site — drop to Marketing lane -->
      <bpmndi:BPMNEdge id="Edge_Flow_Sim_Site" bpmnElement="Flow_Sim_Site">
        <di:waypoint x="2290" y="405"/>
        <di:waypoint x="2290" y="510"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2298" y="450" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Nao_Site" bpmnElement="Flow_Nao_Site">
        <di:waypoint x="2315" y="380"/>
        <di:waypoint x="2405" y="380"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2350" y="362" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- SiteFeito — Marketing→CR merge -->
      <bpmndi:BPMNEdge id="Edge_Flow_SiteFeito" bpmnElement="Flow_SiteFeito">
        <di:waypoint x="2350" y="550"/>
        <di:waypoint x="2430" y="550"/>
        <di:waypoint x="2430" y="405"/>
      </bpmndi:BPMNEdge>

      <!-- GW_MergePublicacao → GW_VisibilidadeConselho (cross-lane CR→AR, backward X) -->
      <bpmndi:BPMNEdge id="Edge_Flow_ParaConselho" bpmnElement="Flow_ParaConselho">
        <di:waypoint x="2430" y="355"/>
        <di:waypoint x="2430" y="280"/>
        <di:waypoint x="2320" y="280"/>
        <di:waypoint x="2320" y="205"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="Edge_Flow_Fim" bpmnElement="Flow_Fim">
        <di:waypoint x="2730" y="380"/>
        <di:waypoint x="2792" y="380"/>
      </bpmndi:BPMNEdge>

      <!-- CTI -->
      <bpmndi:BPMNEdge id="Edge_Flow_A_Analisa" bpmnElement="Flow_A_Analisa">
        <di:waypoint x="738" y="720"/>
        <di:waypoint x="820" y="720"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_AnalisaGW" bpmnElement="Flow_AnalisaGW">
        <di:waypoint x="940" y="720"/>
        <di:waypoint x="1005" y="720"/>
      </bpmndi:BPMNEdge>

      <!-- Não C — forward to LinkThrow_C -->
      <bpmndi:BPMNEdge id="Edge_Flow_Nao_C" bpmnElement="Flow_Nao_C">
        <di:waypoint x="1055" y="720"/>
        <di:waypoint x="1122" y="720"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1072" y="702" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Sim B CTI — drop below GW to LinkThrow_B_CTI -->
      <bpmndi:BPMNEdge id="Edge_Flow_Sim_B_CTI" bpmnElement="Flow_Sim_B_CTI">
        <di:waypoint x="1030" y="745"/>
        <di:waypoint x="1030" y="780"/>
        <di:waypoint x="1072" y="780"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1038" y="755" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- ── DataStore Shapes (cilindros abaixo do diagrama) ── -->
      <!-- Sistema origem: alinhado com Task_ElaborarDocumento (x=390) -->
      <bpmndi:BPMNShape id="Shape_DSRef_BlueFleet" bpmnElement="DSRef_BlueFleet">
        <dc:Bounds x="390" y="855" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="365" y="912" width="100" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <!-- SAP ERP: alinhado com Task_PublicarPortal (x=2090) -->
      <bpmndi:BPMNShape id="Shape_DSRef_SAP" bpmnElement="DSRef_SAP">
        <dc:Bounds x="2090" y="855" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2065" y="912" width="100" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ── Data Association Edges ── -->
      <!-- DIA: Sistema origem → Task_ElaborarDocumento (leitura — seta tracejada chegando na task) -->
      <bpmndi:BPMNEdge id="Edge_DIA_BlueFleet" bpmnElement="DIA_BlueFleet">
        <di:waypoint x="415" y="855"/>
        <di:waypoint x="415" y="220"/>
      </bpmndi:BPMNEdge>
      <!-- DOA: Task_PublicarPortal → SAP ERP (escrita — seta tracejada saindo da task) -->
      <bpmndi:BPMNEdge id="Edge_DOA_SAP" bpmnElement="DOA_SAP">
        <di:waypoint x="2150" y="420"/>
        <di:waypoint x="2150" y="855"/>
        <di:waypoint x="2115" y="855"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>
