        <di:waypoint x="2090" y="380"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2040" y="362" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Reprovado — backward loop routed below -->
      <bpmndi:BPMNEdge id="Edge_Flow_Reprovado" bpmnElement="Flow_Reprovado">
        <di:waypoint x="2000" y="405"/>
        <di:waypoint x="2000" y="462"/>
        <di:waypoint x="1700" y="462"/>
        <di:waypoint x="1700" y="405"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1840" y="444" width="22" height="14"/></bpmndi:BPMNLabel>
