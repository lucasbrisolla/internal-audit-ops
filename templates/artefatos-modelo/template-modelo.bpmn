      <bpmndi:BPMNShape id="Shape_LinkThrow_B_CTI" bpmnElement="LinkThrow_B_CTI">
        <dc:Bounds x="1072" y="762" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1082" y="805" width="16" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ══ SEQUENCE FLOW EDGES ══ -->

      <!-- AR — início -->
      <bpmndi:BPMNEdge id="Edge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="178" y="180"/>
        <di:waypoint x="230" y="180"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="350" y="180"/>
        <di:waypoint x="390" y="180"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_3" bpmnElement="Flow_3">
        <di:waypoint x="510" y="180"/>
        <di:waypoint x="585" y="180"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Sim_A" bpmnElement="Flow_Sim_A">
        <di:waypoint x="635" y="180"/>
        <di:waypoint x="702" y="180"/>
        <bpmndi:BPMNLabel><dc:Bounds x="652" y="162" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- Não direto — routed above AR elements -->
      <bpmndi:BPMNEdge id="Edge_Flow_Nao_Direto" bpmnElement="Flow_Nao_Direto">
        <di:waypoint x="610" y="155"/>
        <di:waypoint x="610" y="100"/>
        <di:waypoint x="1120" y="100"/>
        <di:waypoint x="1120" y="155"/>
        <bpmndi:BPMNLabel><dc:Bounds x="855" y="82" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <!-- AR — correções -->
      <bpmndi:BPMNEdge id="Edge_Flow_B_Correcoes" bpmnElement="Flow_B_Correcoes">
        <di:waypoint x="878" y="180"/>
        <di:waypoint x="960" y="180"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CorrecoesMerge" bpmnElement="Flow_CorrecoesMerge">
        <di:waypoint x="1080" y="180"/>
        <di:waypoint x="1095" y="180"/>
      </bpmndi:BPMNEdge>

      <!-- GW_MergeRetorno → GW_MergeRevisao (cross-lane AR→CR) -->
      <bpmndi:BPMNEdge id="Edge_Flow_ParaRevisao" bpmnElement="Flow_ParaRevisao">
        <di:waypoint x="1145" y="180"/>
        <di:waypoint x="1200" y="180"/>
        <di:waypoint x="1200" y="355"/>
      </bpmndi:BPMNEdge>

      <!-- AR — visibilidade Conselho -->
      <bpmndi:BPMNEdge id="Edge_Flow_Sim_CA" bpmnElement="Flow_Sim_CA">
        <di:waypoint x="2345" y="180"/>
        <di:waypoint x="2400" y="180"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2358" y="162" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_Nao_CA" bpmnElement="Flow_Nao_CA">
        <di:waypoint x="2320" y="155"/>
        <di:waypoint x="2320" y="100"/>
        <di:waypoint x="2580" y="100"/>
        <di:waypoint x="2580" y="155"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2440" y="82" width="22" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_CA_Merge" bpmnElement="Flow_CA_Merge">
        <di:waypoint x="2520" y="180"/>
        <di:waypoint x="2555" y="180"/>
      </bpmndi:BPMNEdge>

      <!-- GW_MergeVisibilidade → Task_AcompanharPrazos (cross-lane AR→CR) -->
      <bpmndi:BPMNEdge id="Edge_Flow_ParaComite" bpmnElement="Flow_ParaComite">
        <di:waypoint x="2605" y="180"/>
        <di:waypoint x="2670" y="180"/>
        <di:waypoint x="2670" y="340"/>
      </bpmndi:BPMNEdge>

      <!-- CR -->
      <bpmndi:BPMNEdge id="Edge_Flow_C_MergeRevisao" bpmnElement="Flow_C_MergeRevisao">
        <di:waypoint x="1068" y="380"/>
        <di:waypoint x="1175" y="380"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_ParaRevDoc" bpmnElement="Flow_ParaRevDoc">
        <di:waypoint x="1225" y="380"/>
        <di:waypoint x="1290" y="380"/>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Edge_Flow_RevDocGW" bpmnElement="Flow_RevDocGW">
