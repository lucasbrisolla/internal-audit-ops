<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  xmlns:bioc="http://bpmn.io/schema/bpmn/biocolor/1.0"
  xmlns:color="http://www.omg.org/spec/BPMN/non-normative/color/1.0"
  id="Definitions_Normativo"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <!-- DataStores globais — cilindros reutilizáveis em qualquer processo -->
  <bpmn:dataStore id="DS_SAP" name="SAP ERP" isUnlimited="true"/>
  <bpmn:dataStore id="DS_SistemaOrigem" name="Sistema Origem" isUnlimited="true"/>

  <bpmn:process id="Process_Normativo" name="Gestão de Normativos" isExecutable="false">

    <bpmn:laneSet id="LaneSet_1">

      <bpmn:lane id="Lane_AreaResponsavel" name="Área Responsável">
        <bpmn:flowNodeRef>StartEvent_1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ObterTemplate</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_ElaborarDocumento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_AvaliacaoOutrasAreas</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>LinkThrow_A</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>LinkCatch_B</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EfetuarCorrecoes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MergeRetorno</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_VisibilidadeConselho</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarCA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MergeVisibilidade</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_ControleRiscos" name="Controle de Riscos">
        <bpmn:flowNodeRef>LinkCatch_C</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MergeRevisao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_RevisarDocumento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_NecessarioCorrecoes</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>LinkThrow_B_CR</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MergeAprovacao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EnviarAprovacao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_DocumentoAprovado</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_PublicarPortal</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_PublicarSite</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_MergePublicacao</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AcompanharPrazos</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_1</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_Marketing" name="Marketing">
        <bpmn:flowNodeRef>Task_PublicarSite</bpmn:flowNodeRef>
      </bpmn:lane>

      <bpmn:lane id="Lane_ComplianceTI" name="Compliance, TI, de Mais Áreas">
        <bpmn:flowNodeRef>LinkCatch_A</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AnalisarDocumento</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_CorrecoesCTI</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>LinkThrow_C</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>LinkThrow_B_CTI</bpmn:flowNodeRef>
      </bpmn:lane>

    </bpmn:laneSet>

    <!-- ══════════════════════════════════════════
         ÁREA RESPONSÁVEL
    ══════════════════════════════════════════ -->

    <bpmn:startEvent id="StartEvent_1" name="Necessidade de normativo identificada">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:userTask id="Task_ObterTemplate" name="Obter template do normativo">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:userTask id="Task_ElaborarDocumento" name="Elaborar / Revisar documento">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3</bpmn:outgoing>
      <!-- lê template/dados do sistema documental (dataInputAssociation = seta tracejada → task) -->
      <bpmn:dataInputAssociation id="DIA_SistemaOrigem">
        <bpmn:sourceRef>DSRef_SistemaOrigem</bpmn:sourceRef>
        <bpmn:targetRef>Task_ElaborarDocumento</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_AvaliacaoOutrasAreas" name="Necessário avaliação de outras áreas?">
      <bpmn:incoming>Flow_3</bpmn:incoming>
      <bpmn:outgoing>Flow_Sim_A</bpmn:outgoing>
      <bpmn:outgoing>Flow_Nao_Direto</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Link A — throw: envia para Compliance / TI -->
    <bpmn:intermediateThrowEvent id="LinkThrow_A" name="A">
      <bpmn:incoming>Flow_Sim_A</bpmn:incoming>
      <bpmn:linkEventDefinition id="LinkDef_ThrowA" name="A"/>
    </bpmn:intermediateThrowEvent>

    <!-- Link B — catch: recebe correções de Compliance/TI ou Controle de Riscos -->
    <bpmn:intermediateCatchEvent id="LinkCatch_B" name="B">
      <bpmn:outgoing>Flow_B_Correcoes</bpmn:outgoing>
      <bpmn:linkEventDefinition id="LinkDef_CatchB" name="B"/>
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="Task_EfetuarCorrecoes" name="Efetuar correções">
      <bpmn:incoming>Flow_B_Correcoes</bpmn:incoming>
      <bpmn:outgoing>Flow_CorrecoesMerge</bpmn:outgoing>
    </bpmn:userTask>

    <!-- Merge: correções concluídas + caminho sem avaliação -->
    <bpmn:exclusiveGateway id="GW_MergeRetorno" name="">
      <bpmn:incoming>Flow_CorrecoesMerge</bpmn:incoming>
      <bpmn:incoming>Flow_Nao_Direto</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaRevisao</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_VisibilidadeConselho" name="Necessário dar visibilidade ao Conselho?">
      <bpmn:incoming>Flow_ParaConselho</bpmn:incoming>
      <bpmn:outgoing>Flow_Sim_CA</bpmn:outgoing>
      <bpmn:outgoing>Flow_Nao_CA</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sendTask id="Task_EnviarCA" name="Enviar para visibilidade ao CA">
      <bpmn:incoming>Flow_Sim_CA</bpmn:incoming>
      <bpmn:outgoing>Flow_CA_Merge</bpmn:outgoing>
    </bpmn:sendTask>

    <bpmn:exclusiveGateway id="GW_MergeVisibilidade" name="">
      <bpmn:incoming>Flow_CA_Merge</bpmn:incoming>
      <bpmn:incoming>Flow_Nao_CA</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaComite</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- ══════════════════════════════════════════
         CONTROLE DE RISCOS
    ══════════════════════════════════════════ -->

    <!-- Link C — catch: recebe documento aprovado por Compliance/TI -->
    <bpmn:intermediateCatchEvent id="LinkCatch_C" name="C">
      <bpmn:outgoing>Flow_C_MergeRevisao</bpmn:outgoing>
      <bpmn:linkEventDefinition id="LinkDef_CatchC" name="C"/>
    </bpmn:intermediateCatchEvent>

    <!-- Merge: documento vindo de C ou de correção direta -->
    <bpmn:exclusiveGateway id="GW_MergeRevisao" name="">
      <bpmn:incoming>Flow_C_MergeRevisao</bpmn:incoming>
      <bpmn:incoming>Flow_ParaRevisao</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaRevDoc</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_RevisarDocumento" name="Revisar o documento">
      <bpmn:incoming>Flow_ParaRevDoc</bpmn:incoming>
      <bpmn:outgoing>Flow_RevDocGW</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_NecessarioCorrecoes" name="Necessário correções?">
      <bpmn:incoming>Flow_RevDocGW</bpmn:incoming>
      <bpmn:outgoing>Flow_Sim_B_CR</bpmn:outgoing>
      <bpmn:outgoing>Flow_Nao_Aprovacao</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Link B — throw: Controle de Riscos solicita correções à Área Responsável -->
    <bpmn:intermediateThrowEvent id="LinkThrow_B_CR" name="B">
      <bpmn:incoming>Flow_Sim_B_CR</bpmn:incoming>
      <bpmn:linkEventDefinition id="LinkDef_ThrowB_CR" name="B"/>
    </bpmn:intermediateThrowEvent>

    <!-- Merge antes de enviar para aprovação (recebe "Não" de correções e retorno de reprovação) -->
    <bpmn:exclusiveGateway id="GW_MergeAprovacao" name="">
      <bpmn:incoming>Flow_Nao_Aprovacao</bpmn:incoming>
      <bpmn:incoming>Flow_Reprovado</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaDocInfo</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_EnviarAprovacao" name="Enviar para aprovação (DocInfo)">
      <bpmn:incoming>Flow_ParaDocInfo</bpmn:incoming>
      <bpmn:outgoing>Flow_DocInfoGW</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GW_DocumentoAprovado" name="Documento aprovado?">
      <bpmn:incoming>Flow_DocInfoGW</bpmn:incoming>
      <bpmn:outgoing>Flow_Aprovado</bpmn:outgoing>
      <bpmn:outgoing>Flow_Reprovado</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:serviceTask id="Task_PublicarPortal" name="Efetuar publicação no Portal">
      <bpmn:incoming>Flow_Aprovado</bpmn:incoming>
      <bpmn:outgoing>Flow_PortalGW</bpmn:outgoing>
      <!-- grava no sistema ERP (dataOutputAssociation = seta tracejada task →) -->
      <bpmn:dataOutputAssociation id="DOA_SAP">
        <bpmn:sourceRef>Task_PublicarPortal</bpmn:sourceRef>
        <bpmn:targetRef>DSRef_SAP</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="GW_PublicarSite" name="Necessário publicar no site?">
      <bpmn:incoming>Flow_PortalGW</bpmn:incoming>
      <bpmn:outgoing>Flow_Sim_Site</bpmn:outgoing>
      <bpmn:outgoing>Flow_Nao_Site</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:exclusiveGateway id="GW_MergePublicacao" name="">
      <bpmn:incoming>Flow_SiteFeito</bpmn:incoming>
      <bpmn:incoming>Flow_Nao_Site</bpmn:incoming>
      <bpmn:outgoing>Flow_ParaConselho</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Task_AcompanharPrazos" name="Acompanhar prazos e apresentar no Comitê de Riscos">
      <bpmn:incoming>Flow_ParaComite</bpmn:incoming>
      <bpmn:outgoing>Flow_Fim</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:endEvent id="EndEvent_1" name="Normativo publicado e monitorado">
      <bpmn:incoming>Flow_Fim</bpmn:incoming>
    </bpmn:endEvent>

    <!-- ══════════════════════════════════════════
         MARKETING
    ══════════════════════════════════════════ -->

    <bpmn:serviceTask id="Task_PublicarSite" name="Efetuar publicação no site institucional">
      <bpmn:incoming>Flow_Sim_Site</bpmn:incoming>
      <bpmn:outgoing>Flow_SiteFeito</bpmn:outgoing>
    </bpmn:serviceTask>

    <!-- ══════════════════════════════════════════
         COMPLIANCE, TI, DE MAIS ÁREAS
    ══════════════════════════════════════════ -->

    <!-- Link A — catch: recebe documento para avaliação -->
    <bpmn:intermediateCatchEvent id="LinkCatch_A" name="A">
      <bpmn:outgoing>Flow_A_Analisa</bpmn:outgoing>
      <bpmn:linkEventDefinition id="LinkDef_CatchA" name="A"/>
    </bpmn:intermediateCatchEvent>

    <bpmn:userTask id="Task_AnalisarDocumento" name="Analisar o documento">
      <bpmn:incoming>Flow_A_Analisa</bpmn:incoming>
      <bpmn:outgoing>Flow_AnalisaGW</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:exclusiveGateway id="GW_CorrecoesCTI" name="Necessário correções?">
      <bpmn:incoming>Flow_AnalisaGW</bpmn:incoming>
      <bpmn:outgoing>Flow_Sim_B_CTI</bpmn:outgoing>
      <bpmn:outgoing>Flow_Nao_C</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <!-- Link B — throw: Compliance/TI solicita correções à Área Responsável -->
    <bpmn:intermediateThrowEvent id="LinkThrow_B_CTI" name="B">
      <bpmn:incoming>Flow_Sim_B_CTI</bpmn:incoming>
      <bpmn:linkEventDefinition id="LinkDef_ThrowB_CTI" name="B"/>
    </bpmn:intermediateThrowEvent>

    <!-- Link C — throw: documento ok, envia para Controle de Riscos -->
    <bpmn:intermediateThrowEvent id="LinkThrow_C" name="C">
      <bpmn:incoming>Flow_Nao_C</bpmn:incoming>
      <bpmn:linkEventDefinition id="LinkDef_ThrowC" name="C"/>
    </bpmn:intermediateThrowEvent>

    <!-- ══════════════════════════════════════════
         SEQUENCE FLOWS
    ══════════════════════════════════════════ -->

    <!-- Área Responsável — início -->
    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_ObterTemplate"/>
    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_ObterTemplate" targetRef="Task_ElaborarDocumento"/>
    <bpmn:sequenceFlow id="Flow_3" sourceRef="Task_ElaborarDocumento" targetRef="GW_AvaliacaoOutrasAreas"/>
    <bpmn:sequenceFlow id="Flow_Sim_A" name="Sim" sourceRef="GW_AvaliacaoOutrasAreas" targetRef="LinkThrow_A"/>
    <bpmn:sequenceFlow id="Flow_Nao_Direto" name="Não" sourceRef="GW_AvaliacaoOutrasAreas" targetRef="GW_MergeRetorno"/>

    <!-- Área Responsável — correções -->
    <bpmn:sequenceFlow id="Flow_B_Correcoes" sourceRef="LinkCatch_B" targetRef="Task_EfetuarCorrecoes"/>
    <bpmn:sequenceFlow id="Flow_CorrecoesMerge" sourceRef="Task_EfetuarCorrecoes" targetRef="GW_MergeRetorno"/>

    <!-- Área Responsável → Controle de Riscos (cross-lane) -->
    <bpmn:sequenceFlow id="Flow_ParaRevisao" sourceRef="GW_MergeRetorno" targetRef="GW_MergeRevisao"/>

    <!-- Área Responsável — visibilidade ao Conselho -->
    <bpmn:sequenceFlow id="Flow_Sim_CA" name="Sim" sourceRef="GW_VisibilidadeConselho" targetRef="Task_EnviarCA"/>
    <bpmn:sequenceFlow id="Flow_Nao_CA" name="Não" sourceRef="GW_VisibilidadeConselho" targetRef="GW_MergeVisibilidade"/>
    <bpmn:sequenceFlow id="Flow_CA_Merge" sourceRef="Task_EnviarCA" targetRef="GW_MergeVisibilidade"/>

    <!-- Área Responsável → Controle de Riscos: depois da visibilidade (cross-lane) -->
    <bpmn:sequenceFlow id="Flow_ParaComite" sourceRef="GW_MergeVisibilidade" targetRef="Task_AcompanharPrazos"/>

    <!-- Controle de Riscos -->
    <bpmn:sequenceFlow id="Flow_C_MergeRevisao" sourceRef="LinkCatch_C" targetRef="GW_MergeRevisao"/>
    <bpmn:sequenceFlow id="Flow_ParaRevDoc" sourceRef="GW_MergeRevisao" targetRef="Task_RevisarDocumento"/>
    <bpmn:sequenceFlow id="Flow_RevDocGW" sourceRef="Task_RevisarDocumento" targetRef="GW_NecessarioCorrecoes"/>
    <bpmn:sequenceFlow id="Flow_Sim_B_CR" name="Sim" sourceRef="GW_NecessarioCorrecoes" targetRef="LinkThrow_B_CR"/>
    <bpmn:sequenceFlow id="Flow_Nao_Aprovacao" name="Não" sourceRef="GW_NecessarioCorrecoes" targetRef="GW_MergeAprovacao"/>
    <bpmn:sequenceFlow id="Flow_ParaDocInfo" sourceRef="GW_MergeAprovacao" targetRef="Task_EnviarAprovacao"/>
    <bpmn:sequenceFlow id="Flow_DocInfoGW" sourceRef="Task_EnviarAprovacao" targetRef="GW_DocumentoAprovado"/>
    <bpmn:sequenceFlow id="Flow_Aprovado" name="Sim" sourceRef="GW_DocumentoAprovado" targetRef="Task_PublicarPortal"/>
    <bpmn:sequenceFlow id="Flow_Reprovado" name="Não" sourceRef="GW_DocumentoAprovado" targetRef="GW_MergeAprovacao"/>
    <bpmn:sequenceFlow id="Flow_PortalGW" sourceRef="Task_PublicarPortal" targetRef="GW_PublicarSite"/>
    <bpmn:sequenceFlow id="Flow_Nao_Site" name="Não" sourceRef="GW_PublicarSite" targetRef="GW_MergePublicacao"/>
    <bpmn:sequenceFlow id="Flow_SiteFeito" sourceRef="Task_PublicarSite" targetRef="GW_MergePublicacao"/>

    <!-- Controle de Riscos → Área Responsável: visibilidade (cross-lane) -->
    <bpmn:sequenceFlow id="Flow_ParaConselho" sourceRef="GW_MergePublicacao" targetRef="GW_VisibilidadeConselho"/>

    <bpmn:sequenceFlow id="Flow_Fim" sourceRef="Task_AcompanharPrazos" targetRef="EndEvent_1"/>

    <!-- Marketing -->
    <bpmn:sequenceFlow id="Flow_Sim_Site" name="Sim" sourceRef="GW_PublicarSite" targetRef="Task_PublicarSite"/>

    <!-- Compliance, TI -->
    <bpmn:sequenceFlow id="Flow_A_Analisa" sourceRef="LinkCatch_A" targetRef="Task_AnalisarDocumento"/>
    <bpmn:sequenceFlow id="Flow_AnalisaGW" sourceRef="Task_AnalisarDocumento" targetRef="GW_CorrecoesCTI"/>
    <bpmn:sequenceFlow id="Flow_Sim_B_CTI" name="Sim" sourceRef="GW_CorrecoesCTI" targetRef="LinkThrow_B_CTI"/>
    <bpmn:sequenceFlow id="Flow_Nao_C" name="Não" sourceRef="GW_CorrecoesCTI" targetRef="LinkThrow_C"/>

    <!-- DataStoreReferences — referenciam os dataStores globais definidos acima -->
    <bpmn:dataStoreReference id="DSRef_SistemaOrigem" name="Sistema Origem" dataStoreRef="DS_SistemaOrigem"/>
    <bpmn:dataStoreReference id="DSRef_SAP" name="SAP ERP" dataStoreRef="DS_SAP"/>

  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_Normativo">

      <!-- ── Lanes ── -->
      <bpmndi:BPMNShape id="Shape_Lane_AR" bpmnElement="Lane_AreaResponsavel" isHorizontal="true">
        <dc:Bounds x="30" y="80" width="2820" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_CR" bpmnElement="Lane_ControleRiscos" isHorizontal="true">
        <dc:Bounds x="30" y="280" width="2820" height="200"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_MKT" bpmnElement="Lane_Marketing" isHorizontal="true">
        <dc:Bounds x="30" y="480" width="2820" height="140"/>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_CTI" bpmnElement="Lane_ComplianceTI" isHorizontal="true">
        <dc:Bounds x="30" y="620" width="2820" height="200"/>
      </bpmndi:BPMNShape>

      <!-- ── AR: Área Responsável (center y=180) ── -->
      <bpmndi:BPMNShape id="Shape_StartEvent_1" bpmnElement="StartEvent_1"
          bioc:stroke="#2e7d32" bioc:fill="#e8f5e9"
          color:background-color="#e8f5e9" color:border-color="#2e7d32">
        <dc:Bounds x="142" y="162" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="110" y="205" width="100" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_ObterTemplate" bpmnElement="Task_ObterTemplate"
          bioc:stroke="#243782" bioc:fill="#e8ebf5"
          color:background-color="#e8ebf5" color:border-color="#243782">
        <dc:Bounds x="230" y="140" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_ElaborarDocumento" bpmnElement="Task_ElaborarDocumento"
          bioc:stroke="#243782" bioc:fill="#e8ebf5"
          color:background-color="#e8ebf5" color:border-color="#243782">
        <dc:Bounds x="390" y="140" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GW_AvaliacaoOutrasAreas" bpmnElement="GW_AvaliacaoOutrasAreas"
          bioc:stroke="#243782" bioc:fill="#fafafa"
          color:background-color="#fafafa" color:border-color="#243782">
        <dc:Bounds x="585" y="155" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="545" y="212" width="130" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_LinkThrow_A" bpmnElement="LinkThrow_A">
        <dc:Bounds x="702" y="162" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="712" y="205" width="16" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_LinkCatch_B" bpmnElement="LinkCatch_B">
        <dc:Bounds x="842" y="162" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="852" y="205" width="16" height="14"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_EfetuarCorrecoes" bpmnElement="Task_EfetuarCorrecoes"
          bioc:stroke="#243782" bioc:fill="#e8ebf5"
          color:background-color="#e8ebf5" color:border-color="#243782">
        <dc:Bounds x="960" y="140" width="120" height="80"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GW_MergeRetorno" bpmnElement="GW_MergeRetorno"
          bioc:stroke="#243782" bioc:fill="#fafafa"
          color:background-color="#fafafa" color:border-color="#243782">
        <dc:Bounds x="1095" y="155" width="50" height="50"/>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_GW_VisibilidadeConselho" bpmnElement="GW_VisibilidadeConselho"
          bioc:stroke="#243782" bioc:fill="#fafafa"
          color:background-color="#fafafa" color:border-color="#243782">
        <dc:Bounds x="2295" y="155" width="50" height="50"/>
        <bpmndi:BPMNLabel><dc:Bounds x="2255" y="212" width="130" height="40"/></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNShape id="Shape_Task_EnviarCA" bpmnElement="Task_EnviarCA"
          bioc:stroke="#1565c0" bioc:fill="#e3f2fd"
