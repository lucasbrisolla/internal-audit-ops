      </bpmndi:BPMNEdge>

      <!-- Não — routed below to skip LinkThrow_B_CR -->
      <bpmndi:BPMNEdge id="Edge_Flow_Nao_Aprovacao" bpmnElement="Flow_Nao_Aprovacao">
        <di:waypoint x="1490" y="405"/>
        <di:waypoint x="1490" y="445"/>
        <di:waypoint x="1700" y="445"/>
        <di:waypoint x="1700" y="405"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1585" y="427" width="22" height="14"/></bpmndi:BPMNLabel>
