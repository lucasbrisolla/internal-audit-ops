      <bpmndi:BPMNShape id="Shape_LinkThrow_C" bpmnElement="LinkThrow_C">
        <dc:Bounds x="1122" y="702" width="36" height="36"/>
        <bpmndi:BPMNLabel><dc:Bounds x="1132" y="745" width="16" height="14"/></bpmndi:BPMNLabel>
